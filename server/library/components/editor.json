{
  "type": "div",
  "props": { "data-base-mode": "editor-mode-content" },
  "css": {
    "classes": ["preempt-editor-panel", "editor-mode-content"],
    "cssDef": [
      { "selector": ".preempt-editor-panel", "styles": {
        "gap": "10px", "right": "10px", "border": "1px solid #444", "bottom": "10px",
        "zIndex": "9999", "display": "flex", "padding": "10px", "position": "fixed",
        "alignItems": "flex-end", "background": "#222", "borderRadius": "5px", "flexDirection": "column"
      } },
      { "selector": ".editor-btn", "styles": {
        "padding": "5px 10px", "borderRadius": "3px", "cursor": "pointer", "border": "1px solid #555", "background": "#444", "color": "#fff"
      } },
      { "selector": ".editor-btn-danger", "styles": {
        "background": "#d9534f", "color": "white", "border": "none"
      } },
      { "selector": ".editor-btn-primary", "styles": {
        "background": "#007BFF", "color": "white", "border": "none"
      } },
      { "selector": ".editor-mode-content .btn-save-template", "styles": { "display": "none" } },
      { "selector": ".editor-mode-content .btn-save-component", "styles": { "display": "none" } },
      { "selector": ".editor-mode-template .btn-save-content", "styles": { "display": "none" } },
      { "selector": ".editor-mode-template .btn-save-component", "styles": { "display": "none" } },
      { "selector": ".editor-mode-component .btn-save-content", "styles": { "display": "none" } },
      { "selector": ".editor-mode-component .btn-save-template", "styles": { "display": "none" } }
    ]
  },
  "content": [
    {
      "type": "div",
      "css": { "style": { "gap": "10px", "display": "flex", "flexWrap": "wrap" } },
      "content": [
        { "type": "input", "props": { "id": "template-tags", "placeholder": "Tags (comma separated)" }, "css": { "style": { "padding": "5px" } } },
        { "type": "button", "content": "Save as New Content", "component": [{"target": "handlers.click", "reference": "saveAsNewContent"}], "css": {"classes": ["editor-btn", "btn-save-content"]} },
        { "type": "button", "content": "Save as New Template", "component": [{"target": "handlers.click", "reference": "saveAsNewTemplate"}], "css": {"classes": ["editor-btn", "btn-save-template"]} },
        { "type": "button", "content": "Save as New Component", "component": [{"target": "handlers.click", "reference": "saveAsNewComponent"}], "css": {"classes": ["editor-btn", "btn-save-component"]} },
        { "type": "button", "content": "Commit Modifications to Component", "component": [{"target": "handlers.click", "reference": "commitComponentChanges"}], "css": {"classes": ["editor-btn", "btn-save-component", "editor-btn-primary"]} },
        { "type": "button", "content": "Commit Modifications to Original", "component": [{"target": "handlers.click", "reference": "saveNodeChanges"}], "css": {"classes": ["editor-btn", "editor-btn-primary"]} },
        { "type": "button", "content": "Discard Edits", "component": [{"target": "handlers.click", "reference": "discardNodeChanges"}], "css": {"classes": ["editor-btn"]} }
      ]
    },
    {
      "type": "pre",
      "css": {
        "id": "editor-inspector-display",
        "style": {
          "color": "#0f0", "width": "350px", "margin": "0", "fontSize": "11px",
          "overflow": "auto", "maxHeight": "300px", "background": "#000", "padding": "10px", "borderRadius": "4px"
        }
      },
      "component": [
        {"target": "content", "reference": "inspectedNodeData", "value": ""}
      ]
    },
    {
      "type": "component",
      "props": { "name": "articlePublishModal" }
    }
  ]
}
