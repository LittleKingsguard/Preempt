{
  "type": "details",
  "css": {
    "classes": [
      "inspector-details"
    ]
  },
  "children": [
    {
      "type": "summary",
      "content": "Placements",
      "css": {
        "classes": [
          "inspector-summary"
        ]
      }
    },
    {
      "type": "div",
      "children": [
        {
          "type": "div",
          "css": {
            "id": "inspector-placements-fields",
            "classes": [
              "fields-container"
            ]
          },
          "placement": [
            {
              "placementName": "inspector-placements-fields"
            }
          ]
        },
        {
          "type": "div",
          "children": [
            {
              "type": "button",
              "content": "Add Placement",
              "props": {
                "data-add-type": "value",
                "data-target-id": "inspector-placements-fields"
              },
              "component": [
                {
                  "target": "handlers.click",
                  "reference": "editorAddField"
                }
              ]
            },
            {
              "type": "button",
              "content": "Update",
              "props": {
                "data-prop-path": "placement.targetPlacement",
                "data-struct": "array_of_strings",
                "data-target-id": "inspector-placements-fields"
              },
              "component": [
                {
                  "target": "handlers.click",
                  "reference": "editorUpdateNodeProp"
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}