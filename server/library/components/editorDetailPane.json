{
  "type": "div",
  "css": {
    "classes": ["editor-detail-pane"],
    "cssDef": [
      {
        "selector": ".editor-detail-pane",
        "styles": {
          "background": "#222",
          "color": "#fff",
          "padding": "20px",
          "borderRadius": "8px",
          "width": "80%",
          "maxWidth": "800px",
          "maxHeight": "90vh",
          "display": "flex",
          "flexDirection": "column",
          "gap": "15px",
          "boxShadow": "0 4px 15px rgba(0,0,0,0.5)"
        }
      },
      {
        "selector": ".editor-detail-pane textarea",
        "styles": {
          "width": "100%",
          "height": "400px",
          "background": "#111",
          "color": "#e0e0e0",
          "border": "1px solid #444",
          "padding": "10px",
          "fontFamily": "monospace",
          "fontSize": "14px",
          "borderRadius": "4px",
          "resize": "vertical",
          "boxSizing": "border-box"
        }
      },
      {
        "selector": ".editor-detail-pane-header",
        "styles": {
          "display": "flex",
          "justifyContent": "space-between",
          "alignItems": "center",
          "borderBottom": "1px solid #444",
          "paddingBottom": "10px"
        }
      },
      {
        "selector": ".editor-detail-pane-title",
        "styles": {
          "fontSize": "18px",
          "fontWeight": "bold",
          "margin": "0"
        }
      },
      {
        "selector": ".editor-detail-pane-actions",
        "styles": {
          "display": "flex",
          "gap": "10px",
          "justifyContent": "flex-end"
        }
      }
    ]
  },
  "children": [
    {
      "type": "div",
      "css": { "classes": ["editor-detail-pane-header"] },
      "children": [
        {
          "type": "h3",
          "css": { "classes": ["editor-detail-pane-title"] },
          "content": "Edit Details"
        }
      ]
    },
    {
      "type": "textarea",
      "props": {
        "inputKey": "editor_detail_pane_content",
        "spellcheck": "false"
      }
    },
    {
      "type": "div",
      "css": { "classes": ["editor-detail-pane-actions"] },
      "children": [
        {
          "type": "button",
          "content": "Test Locally",
          "component": [{"target": "handlers.click", "reference": "editorTestDetailPane"}],
          "css": { "classes": ["editor-btn"] }
        },
        {
          "type": "button",
          "content": "Save to Server",
          "component": [{"target": "handlers.click", "reference": "editorSaveDetailPane"}],
          "css": { "classes": ["editor-btn", "editor-btn-primary"] }
        },
        {
          "type": "button",
          "content": "Close",
          "component": [{"target": "handlers.click", "reference": "editorCloseDetailPane"}],
          "css": { "classes": ["editor-btn", "editor-btn-danger"] }
        }
      ]
    }
  ]
}
