{
  "type": "div",
  "component": [
    { "reference": "userAuthComponent" },
    { "reference": "articleTitle" },
    { "reference": "articleSubtitle" }
  ],
  "css": {
    "classes": [
      "nav-sidebar-desktop"
    ],
    "cssDef": [
      {
        "selector": ".nav-sidebar-desktop",
        "styles": {
          "background": "#ffffff",
          "color": "#333333",
          "minHeight": "100vh",
          "display": "flex",
          "flexDirection": "column"
        }
      },
      {
        "selector": ".nav-sidebar-sidebar",
        "styles": {
          "width": "250px",
          "padding": "2rem",
          "borderRight": "1px solid #eaeaea"
        }
      },
      {
        "selector": "@media (prefers-color-scheme: dark)",
        "styles": {
          ".nav-sidebar-desktop": {
            "background": "#121212",
            "color": "#e0e0e0"
          },
          ".nav-sidebar-sidebar": {
            "borderRight": "1px solid #333"
          }
        }
      }
    ]
  },
  "content": [
    {
      "type": "div",
      "component": [
        {
          "target": "content",
          "reference": "navBar"
        }
      ]
    },
    {
      "type": "div",
      "component": [
        {
          "target": "content",
          "reference": "header"
        }
      ]
    },
    {
      "type": "div",
      "css": {
        "style": {
          "display": "flex",
          "flex": "1",
          "maxWidth": "1200px",
          "margin": "0 auto",
          "width": "100%"
        }
      },
      "content": [
        {
          "type": "nav",
          "css": {
            "classes": [
              "nav-sidebar-sidebar"
            ]
          },
          "placement": {
            "placementName": "sidebar"
          }
        },
        {
          "type": "div",
          "css": {
            "style": {
              "flex": "1",
              "padding": "2rem"
            }
          },
          "content": [
            {
              "type": "div",
              "placement": {
                "placementName": "article"
              }
            },
            {
              "type": "button",
              "content": "Show Comments",
              "component": [
                {
                  "target": "handlers.onLoad",
                  "reference": "toggleCommentsButton"
                },
                {
                  "target": "handlers.click",
                  "reference": "showComments"
                }
              ],
              "css": {
                "style": {
                  "marginTop": "2rem",
                  "padding": "10px 20px",
                  "background": "#42b883",
                  "color": "white",
                  "border": "none",
                  "borderRadius": "4px",
                  "cursor": "pointer",
                  "fontSize": "1rem",
                  "fontWeight": "bold",
                  "width": "100%"
                }
              }
            }
          ]
        }
      ]
    },
    {
      "type": "div",
      "component": [
        {
          "target": "content",
          "reference": "footer"
        }
      ]
    }
  ]
}