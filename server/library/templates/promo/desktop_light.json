{
  "type": "div",
  "css": {
    "style": {
      "background": "#ffffff",
      "color": "#333333",
      "minHeight": "100vh",
      "display": "flex",
      "flexDirection": "column"
    }
  },
  "content": [
    {
      "type": "div",
      "component": [
        {
          "target": "content",
          "reference": "navBar"
        }
      ]
    },
    {
      "type": "div",
      "component": [
        {
          "target": "content",
          "reference": "header"
        }
      ]
    },
    {
      "type": "div",
      "css": {
        "style": {
          "flex": "1",
          "padding": "2rem",
          "maxWidth": "1200px",
          "margin": "0 auto",
          "width": "100%"
        }
      },
      "content": [
        {
          "type": "div",
          "placement": {
            "placementName": "main"
          }
        },
        {
          "type": "button",
          "content": "Show Comments",
          "component": [
            {
              "target": "handlers.onLoad",
              "reference": "toggleCommentsButton"
            },
            {
              "target": "handlers.click",
              "reference": "showComments"
            }
          ],
          "css": {
            "style": {
              "marginTop": "2rem",
              "padding": "10px 20px",
              "background": "#42b883",
              "color": "white",
              "border": "none",
              "borderRadius": "4px",
              "cursor": "pointer",
              "fontSize": "1rem",
              "fontWeight": "bold",
              "width": "100%"
            }
          }
        }
      ]
    },
    {
      "type": "div",
      "component": [
        {
          "target": "content",
          "reference": "footer"
        }
      ]
    }
  ]
}