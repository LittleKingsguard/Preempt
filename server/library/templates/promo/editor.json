{
  "root": {
    "type": "div",
    "css": {
      "style": {
        "background": "#ffffff",
        "color": "#333333",
        "minHeight": "100vh",
        "display": "flex",
        "flexDirection": "column"
      }
    },
    "children": [
      {
        "type": "div",
        "component": [
          {
            "target": "content",
            "reference": "navBar"
          }
        ]
      },
      {
        "type": "div",
        "component": [
          {
            "target": "content",
            "reference": "header"
          }
        ]
      },
      {
        "type": "div",
        "css": {
          "style": {
            "flex": "1",
            "padding": "2rem",
            "maxWidth": "1200px",
            "margin": "0 auto",
            "width": "100%"
          }
        },
        "children": [
          {
            "type": "div",
            "placement": [
              {
                "placementName": "main"
              }
            ]
          },
          {
            "type": "button",
            "content": "Show Comments",
            "component": [
              {
                "target": "handlers.onLoad",
                "reference": "toggleCommentsButton"
              },
              {
                "target": "handlers.click",
                "reference": "showComments"
              }
            ],
            "css": {
              "style": {
                "marginTop": "2rem",
                "padding": "10px 20px",
                "background": "#42b883",
                "color": "white",
                "border": "none",
                "borderRadius": "4px",
                "cursor": "pointer",
                "fontSize": "1rem",
                "fontWeight": "bold",
                "width": "100%"
              }
            }
          }
        ]
      },
      {
        "type": "div",
        "component": [
          {
            "target": "content",
            "reference": "footer"
          }
        ]
      },
      {
        "type": "div",
        "component": [
          {
            "target": "content",
            "reference": "editor"
          }
        ]
      },
      {
        "type": "div",
        "css": {
          "classes": [
            "preempt-modal-placement"
          ],
          "cssDef": [
            {
              "selector": ".preempt-modal-placement",
              "styles": {
                "position": "fixed",
                "top": "0",
                "left": "0",
                "width": "100%",
                "height": "100%",
                "background": "rgba(0, 0, 0, 0.5)",
                "display": "flex",
                "justifyContent": "center",
                "alignItems": "center",
                "zIndex": "9999"
              }
            }
          ]
        },
        "placement": [
          {
            "placementName": "modal"
          }
        ]
      }
    ]
  },
  "children": []
}