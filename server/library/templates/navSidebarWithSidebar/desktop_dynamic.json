{
  "type": "div",
  "css": { 
    "classes": ["nav-sidebar-double-desktop"],
    "cssDef": [
      { "selector": ".nav-sidebar-double-desktop", "styles": { "background": "#ffffff", "color": "#333333", "minHeight": "100vh", "display": "flex", "flexDirection": "column" } },
      { "selector": ".sidebar-left", "styles": { "width": "200px", "padding": "1.5rem", "borderRight": "1px solid #eaeaea" } },
      { "selector": ".sidebar-right", "styles": { "width": "250px", "padding": "1.5rem", "borderLeft": "1px solid #eaeaea" } },
      { "selector": "@media (prefers-color-scheme: dark)", "styles": { 
          ".nav-sidebar-double-desktop": { "background": "#121212", "color": "#e0e0e0" },
          ".sidebar-left": { "borderRight": "1px solid #333" },
          ".sidebar-right": { "borderLeft": "1px solid #333" }
      } }
    ]
  },
  "content": [
    { "type": "div", "component": [{"target": "content", "reference": "navBar"}] },
    { "type": "div", "component": [{"target": "content", "reference": "header"}] },
    { "type": "div", "css": { "style": { "display": "flex", "flex": "1", "maxWidth": "1400px", "margin": "0 auto", "width": "100%" } }, "content": [
        { "type": "nav", "css": { "classes": ["sidebar-left"] }, "placement": {"placementName": "sidebar_left"} },
        { "type": "main", "css": { "style": { "flex": "1", "padding": "2rem" } }, "placement": {"placementName": "article"} },
        { "type": "aside", "css": { "classes": ["sidebar-right"] }, "placement": {"placementName": "sidebar_right"} }
    ] },
    { "type": "div", "component": [{"target": "content", "reference": "footer"}] }
  ]
}
