{
  "type": "div",
  "css": {
    "classes": [
      "nav-sidebar-double-mobile"
    ],
    "cssDef": [
      {
        "selector": ".nav-sidebar-double-mobile",
        "styles": {
          "background": "#ffffff",
          "color": "#333333",
          "minHeight": "100vh",
          "display": "flex",
          "flexDirection": "column"
        }
      },
      {
        "selector": ".sidebar-left-mobile",
        "styles": {
          "padding": "1rem",
          "borderBottom": "1px solid #eaeaea"
        }
      },
      {
        "selector": ".sidebar-right-mobile",
        "styles": {
          "padding": "1rem",
          "borderTop": "1px solid #eaeaea"
        }
      },
      {
        "selector": "@media (prefers-color-scheme: dark)",
        "styles": {
          ".nav-sidebar-double-mobile": {
            "background": "#121212",
            "color": "#e0e0e0"
          },
          ".sidebar-left-mobile": {
            "borderBottom": "1px solid #333"
          },
          ".sidebar-right-mobile": {
            "borderTop": "1px solid #333"
          }
        }
      }
    ]
  },
  "content": [
    {
      "type": "div",
      "component": [
        {
          "target": "content",
          "reference": "navBar"
        }
      ]
    },
    {
      "type": "div",
      "component": [
        {
          "target": "content",
          "reference": "header"
        }
      ]
    },
    {
      "type": "div",
      "css": {
        "style": {
          "display": "flex",
          "flexDirection": "column",
          "flex": "1",
          "width": "100%"
        }
      },
      "content": [
        {
          "type": "nav",
          "css": {
            "classes": [
              "sidebar-left-mobile"
            ]
          },
          "placement": {
            "placementName": "sidebar_left"
          }
        },
        {
          "type": "div",
          "css": {
            "style": {
              "flex": "1",
              "padding": "1rem"
            }
          },
          "content": [
            {
              "type": "div",
              "placement": {
                "placementName": "article"
              }
            },
            {
              "type": "button",
              "content": "Show Comments",
              "component": [
                {
                  "target": "handlers.onLoad",
                  "reference": "toggleCommentsButton"
                },
                {
                  "target": "handlers.click",
                  "reference": "showComments"
                }
              ],
              "css": {
                "style": {
                  "marginTop": "2rem",
                  "padding": "10px 20px",
                  "background": "#42b883",
                  "color": "white",
                  "border": "none",
                  "borderRadius": "4px",
                  "cursor": "pointer",
                  "fontSize": "1rem",
                  "fontWeight": "bold",
                  "width": "100%"
                }
              }
            }
          ]
        },
        {
          "type": "aside",
          "css": {
            "classes": [
              "sidebar-right-mobile"
            ]
          },
          "placement": {
            "placementName": "sidebar_right"
          }
        }
      ]
    },
    {
      "type": "div",
      "component": [
        {
          "target": "content",
          "reference": "footer"
        }
      ]
    },
    {
      "type": "div",
      "css": {
        "style": {
          "display": "none"
        }
      },
      "component": [
        {
          "target": "type",
          "reference": "adminDashboardLink"
        }
      ],
      "placement": {
        "targetPlacement": [
          "adminLinks"
        ]
      }
    },
    {
      "type": "div",
      "css": {
        "style": {
          "display": "none"
        }
      },
      "component": [
        {
          "target": "type",
          "reference": "editContentLink"
        }
      ],
      "placement": {
        "targetPlacement": [
          "contributorLinks"
        ]
      }
    },
    {
      "type": "div",
      "css": {
        "style": {
          "display": "none"
        }
      },
      "component": [
        {
          "target": "type",
          "reference": "createArticleLink"
        }
      ],
      "placement": {
        "targetPlacement": [
          "contributorLinks"
        ]
      }
    },
    {
      "type": "div",
      "css": {
        "classes": [
          "preempt-modal-placement"
        ],
        "cssDef": [
          {
            "selector": ".preempt-modal-placement",
            "styles": {
              "position": "fixed",
              "top": "0",
              "left": "0",
              "width": "100%",
              "height": "100%",
              "background": "rgba(0, 0, 0, 0.5)",
              "display": "flex",
              "justifyContent": "center",
              "alignItems": "center",
              "zIndex": "9999"
            }
          }
        ]
      },
      "placement": {
        "placementName": "modal"
      }
    }
  ]
}
