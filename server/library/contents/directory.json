{
  "type": "div",
  "css": { "style": { "padding": "2rem", "fontFamily": "sans-serif" } },
  "component": [{"target": "handlers.onLoad", "reference": "onDBLoad_directory"}],
  "content": [
    { "type": "h1", "content": "Article Directory", "css": {"style": {"borderBottom": "2px solid #eaeaea", "paddingBottom": "0.5rem", "marginBottom": "1.5rem"}} },
    { 
      "type": "div",
      "props": { "id": "directory-list" },
      "css": { "style": { "display": "grid", "gap": "1rem", "gridTemplateColumns": "repeat(auto-fill, minmax(300px, 1fr))" } },
      "content": [
        { "type": "p", "content": "Loading articles...", "css": {"style": {"color": "#666"}} }
      ]
    }
  ]
}
