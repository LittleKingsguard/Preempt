{
    "css": {
        "style": {
            "border": "1px solid #ccc",
            "padding": "20px",
            "maxWidth": "300px",
            "background": "#f9f9f9",
            "borderRadius": "8px"
        },
        "classes": [
            "login-component-container"
        ]
    },
    "type": "div",
    "children": [
        {
            "css": {
                "style": {
                    "gap": "10px",
                    "display": "flex",
                    "marginBottom": "15px"
                }
            },
            "type": "div",
            "children": [
                {
                    "type": "button",
                    "props": {
                        "data-target": "login"
                    },
                    "content": "Login",
                    "component": [
                        {
                            "target": "handlers.click",
                            "reference": "TabToggleHandler"
                        }
                    ]
                },
                {
                    "type": "button",
                    "props": {
                        "data-target": "register"
                    },
                    "content": "Register",
                    "component": [
                        {
                            "target": "handlers.click",
                            "reference": "TabToggleHandler"
                        }
                    ]
                }
            ]
        },
        {
            "css": {
                "style": {
                    "display": "block"
                },
                "classes": [
                    "login-form-wrapper"
                ]
            },
            "type": "div",
            "children": [
                {
                    "type": "form",
                    "props": {
                        "action": "#"
                    },
                    "children": [
                        {
                            "css": {
                                "style": {
                                    "width": "100%",
                                    "display": "block",
                                    "marginBottom": "10px"
                                }
                            },
                            "type": "input",
                            "props": {
                                "name": "username",
                                "required": "true",
                                "placeholder": "Username"
                            }
                        },
                        {
                            "css": {
                                "style": {
                                    "width": "100%",
                                    "display": "block",
                                    "marginBottom": "10px"
                                }
                            },
                            "type": "input",
                            "props": {
                                "name": "password",
                                "type": "password",
                                "required": "true",
                                "placeholder": "Password"
                            }
                        },
                        {
                            "type": "button",
                            "props": {
                                "type": "submit"
                            },
                            "content": "Login",
                            "component": [
                                {
                                    "target": "handlers.click",
                                    "reference": "LoginHandler"
                                }
                            ]
                        },
                        {
                            "type": "button",
                            "props": {
                                "type": "button",
                                "data-target": "forgot"
                            },
                            "content": "Forgot Password?",
                            "component": [
                                {
                                    "target": "handlers.click",
                                    "reference": "TabToggleHandler"
                                }
                            ]
                        }
                    ]
                }
            ]
        },
        {
            "css": {
                "style": {
                    "display": "none"
                },
                "classes": [
                    "register-form-wrapper"
                ]
            },
            "type": "div",
            "children": [
                {
                    "type": "form",
                    "props": {
                        "action": "#"
                    },
                    "children": [
                        {
                            "css": {
                                "style": {
                                    "width": "100%",
                                    "display": "block",
                                    "marginBottom": "10px"
                                }
                            },
                            "type": "input",
                            "props": {
                                "name": "username",
                                "required": "true",
                                "placeholder": "Username"
                            }
                        },
                        {
                            "css": {
                                "style": {
                                    "width": "100%",
                                    "display": "block",
                                    "marginBottom": "10px"
                                }
                            },
                            "type": "input",
                            "props": {
                                "name": "email",
                                "type": "email",
                                "required": "true",
                                "placeholder": "Email"
                            }
                        },
                        {
                            "css": {
                                "style": {
                                    "width": "100%",
                                    "display": "block",
                                    "marginBottom": "10px"
                                }
                            },
                            "type": "input",
                            "props": {
                                "name": "password",
                                "type": "password",
                                "required": "true",
                                "placeholder": "Password"
                            }
                        },
                        {
                            "type": "button",
                            "props": {
                                "type": "submit"
                            },
                            "content": "Register",
                            "component": [
                                {
                                    "target": "handlers.click",
                                    "reference": "RegisterHandler"
                                }
                            ]
                        }
                    ]
                }
            ]
        },
        {
            "css": {
                "style": {
                    "display": "none",
                    "textAlign": "center"
                },
                "classes": [
                    "logged-in-wrapper"
                ]
            },
            "type": "div",
            "children": [
                {
                    "type": "h3",
                    "content": "Welcome"
                },
                {
                    "type": "button",
                    "content": "Logout",
                    "component": [
                        {
                            "target": "handlers.click",
                            "reference": "LogoutHandler"
                        }
                    ]
                }
            ]
        },
        {
            "css": {
                "style": {
                    "display": "none"
                },
                "classes": [
                    "2fa-form-wrapper"
                ]
            },
            "type": "div",
            "children": [
                {
                    "type": "form",
                    "props": {
                        "action": "#"
                    },
                    "children": [
                        {
                            "css": {
                                "style": {
                                    "width": "100%",
                                    "display": "none",
                                    "marginBottom": "10px"
                                }
                            },
                            "type": "input",
                            "props": {
                                "name": "username",
                                "type": "hidden"
                            }
                        },
                        {
                            "css": {
                                "style": {
                                    "width": "100%",
                                    "display": "block",
                                    "marginBottom": "10px"
                                }
                            },
                            "type": "input",
                            "props": {
                                "name": "code",
                                "required": "true",
                                "placeholder": "6-digit 2FA Code"
                            }
                        },
                        {
                            "type": "button",
                            "props": {
                                "type": "submit"
                            },
                            "content": "Verify",
                            "component": [
                                {
                                    "target": "handlers.click",
                                    "reference": "Verify2FAHandler"
                                }
                            ]
                        }
                    ]
                }
            ]
        },
        {
            "css": {
                "style": {
                    "display": "none"
                },
                "classes": [
                    "forgot-form-wrapper"
                ]
            },
            "type": "div",
            "children": [
                {
                    "type": "form",
                    "props": {
                        "action": "#"
                    },
                    "children": [
                        {
                            "css": {
                                "style": {
                                    "width": "100%",
                                    "display": "block",
                                    "marginBottom": "10px"
                                }
                            },
                            "type": "input",
                            "props": {
                                "name": "email",
                                "type": "email",
                                "required": "true",
                                "placeholder": "Email Address"
                            }
                        },
                        {
                            "type": "button",
                            "props": {
                                "type": "submit"
                            },
                            "content": "Send Reset Link",
                            "component": [
                                {
                                    "target": "handlers.click",
                                    "reference": "ForgotPasswordHandler"
                                }
                            ]
                        },
                        {
                            "type": "button",
                            "props": {
                                "type": "button",
                                "data-target": "login"
                            },
                            "content": "Back to Login",
                            "component": [
                                {
                                    "target": "handlers.click",
                                    "reference": "TabToggleHandler"
                                }
                            ]
                        }
                    ]
                }
            ]
        },
        {
            "css": {
                "style": {
                    "display": "none"
                }
            },
            "type": "div",
            "children": [
                {
                    "css": {
                        "style": {
                            "marginBottom": "15px"
                        }
                    },
                    "type": "h2",
                    "content": "Verify Your Email"
                },
                {
                    "css": {
                        "style": {
                            "marginBottom": "15px"
                        }
                    },
                    "type": "p",
                    "content": "We've sent a 6-digit code to your email address."
                },
                {
                    "css": {
                        "style": {
                            "gap": "10px",
                            "display": "flex",
                            "flexDirection": "column"
                        }
                    },
                    "type": "form",
                    "props": {
                        "action": "#",
                        "data-handler": "VerifyEmailHandler"
                    },
                    "children": [
                        {
                            "type": "input",
                            "props": {
                                "name": "username",
                                "type": "hidden"
                            }
                        },
                        {
                            "css": {
                                "style": {
                                    "border": "1px solid #ccc",
                                    "padding": "8px",
                                    "borderRadius": "4px"
                                }
                            },
                            "type": "input",
                            "props": {
                                "name": "code",
                                "type": "text",
                                "required": true,
                                "placeholder": "6-digit Code"
                            }
                        },
                        {
                            "css": {
                                "style": {
                                    "color": "#fff",
                                    "border": "none",
                                    "cursor": "pointer",
                                    "padding": "10px",
                                    "background": "#007BFF",
                                    "borderRadius": "4px"
                                }
                            },
                            "type": "button",
                            "props": {
                                "type": "submit"
                            },
                            "content": "Verify"
                        }
                    ]
                }
            ]
        }
    ],
    "component": [
        {
            "target": "handlers.beforeRender",
            "reference": "CheckLoginHandler"
        }
    ]
}
